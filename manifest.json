{
  "manifest_version": 3,
  "name": "The 60-Minute Rule",
  "version": "2.7.0",
  "description": "Structured competitive programming timer. 6 phases. 60 minutes. No excuses.",
  "icons": {
    "48": "icons/icon48.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "The 60-Minute Rule"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "tabs"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T"
      },
      "description": "Open The 60-Minute Rule"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sixty-minute-rule@cp-tools.io"
    }
  },
  "host_permissions": [
    "https://codeforces.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://codeforces.com; style-src 'self' 'unsafe-inline';"
  }
}